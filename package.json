{
  "name": "@lgrammel/llama-cpp-provider-monorepo",
  "private": true,
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  },
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build:ts && changeset publish",
    "prepare": "husky",
    "build": "pnpm -r build",
    "build:ts": "pnpm -r build:ts",
    "build:native": "pnpm --filter @lgrammel/llama-cpp-provider build:native",
    "clean": "pnpm -r clean",
    "test": "pnpm --filter @lgrammel/llama-cpp-provider test",
    "test:run": "pnpm --filter @lgrammel/llama-cpp-provider test:run",
    "test:unit": "pnpm --filter @lgrammel/llama-cpp-provider test:unit",
    "test:integration": "pnpm --filter @lgrammel/llama-cpp-provider test:integration",
    "test:e2e": "pnpm --filter @tests/e2e test:run",
    "test:coverage": "pnpm --filter @lgrammel/llama-cpp-provider test:coverage",
    "typecheck": "pnpm --filter @lgrammel/llama-cpp-provider typecheck && pnpm --filter @examples/basic typecheck && pnpm --filter @tests/e2e typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format:check": "oxfmt --check \"packages/*/src/**/*.ts\" \"packages/*/tests/**/*.ts\" \"examples/**/*.ts\" \"tests/**/*.ts\" && clang-format --dry-run --Werror packages/llama-cpp-provider/native/*.cpp packages/llama-cpp-provider/native/*.h",
    "format:fix": "oxfmt --write \"packages/*/src/**/*.ts\" \"packages/*/tests/**/*.ts\" \"examples/**/*.ts\" \"tests/**/*.ts\" && clang-format -i packages/llama-cpp-provider/native/*.cpp packages/llama-cpp-provider/native/*.h"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "packages/llama-cpp-provider/native/*.{cpp,h}": [
      "clang-format -i"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
