{
  "name": "ai-sdk-llama-cpp-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "tests/*"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  },
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "bun run build:ts && changeset publish",
    "prepare": "husky",
    "build": "bun run --filter ai-sdk-llama-cpp build",
    "build:ts": "bun run --filter ai-sdk-llama-cpp build:ts",
    "build:native": "bun run --filter ai-sdk-llama-cpp build:native",
    "clean": "bun run --filter ai-sdk-llama-cpp clean",
    "test": "bun run --filter ai-sdk-llama-cpp test",
    "test:run": "bun run --filter ai-sdk-llama-cpp test:run",
    "test:unit": "bun run --filter ai-sdk-llama-cpp test:unit",
    "test:integration": "bun run --filter ai-sdk-llama-cpp test:integration",
    "test:e2e": "bun run --filter @tests/e2e test:run",
    "test:coverage": "bun run --filter ai-sdk-llama-cpp test:coverage",
    "typecheck": "bun run --filter ai-sdk-llama-cpp typecheck && bun run --filter @examples/basic typecheck && bun run --filter @tests/e2e typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format:check": "oxfmt --check \"packages/*/src/**/*.ts\" \"packages/*/tests/**/*.ts\" \"examples/**/*.ts\" \"tests/**/*.ts\" && clang-format --dry-run --Werror packages/ai-sdk-llama-cpp/native/*.cpp packages/ai-sdk-llama-cpp/native/*.h",
    "format:fix": "oxfmt --write \"packages/*/src/**/*.ts\" \"packages/*/tests/**/*.ts\" \"examples/**/*.ts\" \"tests/**/*.ts\" && clang-format -i packages/ai-sdk-llama-cpp/native/*.cpp packages/ai-sdk-llama-cpp/native/*.h"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ],
    "packages/ai-sdk-llama-cpp/native/*.{cpp,h}": [
      "clang-format -i"
    ]
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.10"
}
